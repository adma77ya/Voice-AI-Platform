# ============================================================
# Vobiz Voice AI Platform - Backend Environment Variables
# ============================================================
# Copy this file to `.env` and fill in the required values.
# Do NOT commit real credentials or API keys.
# ============================================================


# ============================================================
# Internal Service Authentication
# ============================================================
# Used for service-to-service authentication inside the platform
INTERNAL_API_KEY=example_internal_key


# ============================================================
# LiveKit Configuration (Voice Agent)
# ============================================================
# Obtain credentials from: https://cloud.livekit.io

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Outbound SIP trunk ID used for calling
OUTBOUND_TRUNK_ID=


# ============================================================
# OpenAI Configuration (Realtime Voice)
# ============================================================
# Obtain API key from: https://platform.openai.com/api-keys

OPENAI_API_KEY=

# Available voices: alloy, echo, fable, onyx, nova, shimmer, marin
OPENAI_REALTIME_VOICE=alloy


# ============================================================
# Google APIs (Post-call Analysis / Integrations)
# ============================================================
# Obtain credentials from: https://console.cloud.google.com/apis/credentials

GOOGLE_API_KEY=

# Optional provider keys (only needed if selected in assistant voice settings)
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
CARTESIA_API_KEY=
ASSEMBLYAI_API_KEY=


# ============================================================
# Deepgram (Speech-to-text transcription)
# ============================================================
DEEPGRAM_API_KEY=


# ============================================================
# Google OAuth (Calendar Integration)
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/calendar/google/callback


# ============================================================
# MongoDB Configuration
# ============================================================
# Example format:
# mongodb+srv://username:password@cluster.mongodb.net

MONGODB_URI=
MONGODB_DB_NAME=vobiz_calls


# ============================================================
# Qdrant Vector Database
# ============================================================
# Local Docker default
QDRANT_URL=http://qdrant:6333

# Optional if using Qdrant Cloud
# QDRANT_API_KEY=


# ============================================================
# AWS S3 (Call Recording Storage)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1


# ============================================================
# Vobiz SIP Trunk Configuration
# ============================================================
# SIP provider details used for outbound calls

VOBIZ_SIP_DOMAIN=
VOBIZ_USERNAME=
VOBIZ_PASSWORD=
VOBIZ_OUTBOUND_NUMBER=


# ============================================================
# API Server Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000


# ============================================================
# Authentication / Security
# ============================================================
AUTH_ENABLED=true

# JWT configuration
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ============================================================
# Redis (Cache / Queue)
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300


# ============================================================
# Internal Service URLs
# ============================================================
EMBEDDING_SERVICE_URL=http://embedding-service:8004/embed
GATEWAY_INTERNAL_URL=http://gateway:8000
FRONTEND_URL=http://localhost:5173


# ============================================================
# RAG Retrieval Tuning (Optional)
# ============================================================
RAG_MIN_SCORE=0.0
RAG_DEBUG_TEST_QUERY=
# ============================================================
# Vobiz Voice AI Platform - Environment Variables Example
# ============================================================
# Copy this file to `.env` and fill in the required values.
# Never commit real API keys or credentials to the repository.
# ============================================================


# ============================================================
# LiveKit Configuration
# ============================================================
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit outbound trunk ID for calls
OUTBOUND_TRUNK_ID=


# ============================================================
# OpenAI Configuration
# ============================================================
OPENAI_API_KEY=

# Default voice model used for realtime voice synthesis
OPENAI_REALTIME_VOICE=alloy


# ============================================================
# Google Gemini Configuration (Post-call analysis)
# ============================================================
GOOGLE_API_KEY=

# Google OAuth (Calendar Integration)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/calendar/google/callback


# ============================================================
# Deepgram Configuration (Speech-to-text transcription)
# ============================================================
DEEPGRAM_API_KEY=

# Optional provider keys (only needed if selected in assistant voice settings)
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
CARTESIA_API_KEY=
ASSEMBLYAI_API_KEY=


# ============================================================
# MongoDB Configuration
# ============================================================
# Example:
# mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URI=

# Database name used by the application
MONGODB_DB_NAME=vobiz_calls


# ============================================================
# Qdrant Vector Database
# ============================================================
# Default Docker service URL
QDRANT_URL=http://qdrant:6333


# ============================================================
# Redis Configuration
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300


# ============================================================
# AWS S3 Configuration (Call recordings - Optional)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1


# ============================================================
# API Server Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000


# ============================================================
# Internal Service Authentication / URLs
# ============================================================
INTERNAL_API_KEY=example_internal_key
EMBEDDING_SERVICE_URL=http://embedding-service:8004/embed
GATEWAY_INTERNAL_URL=http://gateway:8000
FRONTEND_URL=http://localhost:5173


# ============================================================
# Authentication / Security
# ============================================================
AUTH_ENABLED=true
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ============================================================
# RAG Retrieval Tuning (Optional)
# ============================================================
RAG_MIN_SCORE=0.0
RAG_DEBUG_TEST_QUERY=


# ============================================================
# Frontend Configuration
# ============================================================
# URL of the backend API used by the frontend
VITE_API_URL=http://localhost:8000
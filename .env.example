# Environment variables template for Vobiz Voice AI Platform
# Copy this to .env and fill in your values

# ===================
# LiveKit Configuration
# ===================
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
OUTBOUND_TRUNK_ID=your_sip_trunk_id

# ===================
# OpenAI Configuration
# ===================
OPENAI_API_KEY=your_openai_api_key
OPENAI_REALTIME_VOICE=alloy

# ===================
# Google Gemini (Post-call Analysis)
# ===================
GOOGLE_API_KEY=your_google_api_key

# ===================
# MongoDB (Override for Docker)
# ===================
MONGODB_URI=mongodb://mongodb:27017/vobiz_calls
MONGODB_DB_NAME=vobiz_calls

# ===================
# Redis (Override for Docker)
# ===================
REDIS_HOST=redis
REDIS_PORT=6379

# ===================
# Qdrant (Vector DB - Override for Docker)
# ===================
QDRANT_URL=http://qdrant:6333

# ===================
# AWS S3 (Recordings - Optional)
# ===================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1

# ===================
# API Server
# ===================
API_HOST=0.0.0.0
API_PORT=8000

# ===================
# Encryption key for workspace integrations
# ===================
INTEGRATION_SECRET_KEY=your-32-byte-url-safe-base64-key

# ===================
# Frontend
# ===================
# In dev, Vite dev server proxies /api to the Gateway; leave VITE_API_URL empty.
# In production, set this to the deployed API origin (e.g. https://api.yourdomain.com).
VITE_API_URL=
